# Streamlit Secrets Configuration Example
# ========================================
#
# 使用说明：
# 1. 复制此文件为 secrets.toml
# 2. 填入你的 API Key 配置
# 3. secrets.toml 应该被 .gitignore 忽略，不要提交到 Git
#
# 对于 Streamlit Cloud 部署，请在 Streamlit Cloud 控制台设置 Secrets
# 对于 GitHub Secrets，请在 GitHub 仓库 Settings -> Secrets 中设置

[general]
# 默认模型提供商 (可选，默认：qwen)
# 支持的提供商：qwen, kimi, doubao, zhipu, baichuan, deepseek, minimax, ollama, custom
provider = "qwen"

# API Key (必填，除非使用 ollama 本地模型)
api_key = "your-api-key-here"

# 自定义模型名称 (可选，留空使用默认)
model_name = ""

# 自定义 API 基础 URL (仅 custom 模式需要)
base_url = ""

# Ollama 模型名称 (仅 ollama 模式需要)
ollama_model = "qwen2.5:7b"

# =============================================================================
# 环境变量方式（用于 GitHub Actions / Streamlit Cloud）
# =============================================================================
#
# 在 GitHub Secrets 中设置以下变量：
# - API_KEY: 你的 API Key
# - DEFAULT_PROVIDER: 默认提供商 (如 qwen)
# - MODEL_NAME: 自定义模型名称 (可选)
# - BASE_URL: 自定义 API 端点 (可选)
